# Copy to backend.hcl (gitignored) and fill in your state bucket details,
# then run: terraform init -backend-config=backend.hcl
#
# The named values here must match what CI/CD supplies via repo
# secrets (TF_STATE_BUCKET, TF_STATE_REGION, TF_LOCK_TABLE) in
# .github/workflows/terraform.yml.

bucket         = "your-terraform-state-bucket"
key            = "S3-Data-Lake-Foundation/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "your-terraform-lock-table"
encrypt        = true
